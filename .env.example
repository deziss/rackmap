# ─── apps/api ────────────────────────────────────────────────────────────────
DATABASE_URL=file:./dev.db
PORT=3000
NODE_ENV=development

# 32 bytes base64 — generate: openssl rand -base64 32
APP_ENCRYPTION_KEY=

# Min 16 chars — generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

BETTER_AUTH_URL=http://localhost:5173
WEB_ORIGIN=http://localhost:5173

# Scheduler
SCHEDULER_ENABLED=true
PING_INTERVAL_MS=60000
PING_TIMEOUT_MS=3000
PING_CONCURRENCY=10
STATUS_RETENTION_DAYS=30
STATUS_FLIP_THRESHOLD=2

# Notifications (optional)
NOTIFY_WEBHOOK_URL=
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=cloudscope@example.com

# --- Live Metrics & Alerts ---
METRICS_ENABLED=true
METRICS_SSH_TIMEOUT_MS=10000

METRICS_ALERT_ENABLED=true
METRICS_ALERT_INTERVAL_MS=300000
ALERT_THRESHOLD_CPU=90
ALERT_THRESHOLD_RAM=95
ALERT_THRESHOLD_DISK=90

# Backup (optional)
BACKUP_DIR=
BACKUP_CRON=0 2 * * *

# Single-process bare-metal: serve web dist from api
SERVE_STATIC_DIR=

# Seed (prisma/seed.ts only)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Change-Me-Now-123!

# ─── apps/web (Vite build-time only) ─────────────────────────────────────────
# Leave empty for same-origin via proxy
VITE_API_URL=
