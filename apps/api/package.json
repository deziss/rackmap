{
  "name": "@inv/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@hono/node-ws": "^1.3.1",
    "@hono/zod-validator": "^0.7.0",
    "@inv/shared": "workspace:*",
    "@prisma/client": "^6.0.0",
    "better-auth": "^1.4.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "hono": "^4.6.0",
    "nodemailer": "^9.0.1",
    "p-limit": "^6.1.0",
    "ssh2": "^1.17.0",
    "xlsx": "^0.18.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/nodemailer": "^8.0.1",
    "@types/ssh2": "^1.15.5",
    "prisma": "^6.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
